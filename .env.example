# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement FRONT (Vite) — instance Supabase
# Copier ce fichier en `.env` (local) et renseigner les valeurs de la NOUVELLE
# instance. NE JAMAIS committer `.env`. Utiliser UNIQUEMENT la clé publique
# (anon / publishable) — JAMAIS la clé service_role côté front.
# Noms exacts attendus par src/integrations/supabase/client.ts.
# ─────────────────────────────────────────────────────────────────────────────

# URL du projet Supabase (ex: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Clé publique anon (utilisée en priorité par client.ts)
VITE_SUPABASE_ANON_KEY=

# Clé publique "publishable" (fallback si VITE_SUPABASE_ANON_KEY est absent)
VITE_SUPABASE_PUBLISHABLE_KEY=
